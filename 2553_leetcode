class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) {
        vector<int> ans ; 
        for(int num : nums){
        vector<int> Dans ; 
            while(num != 0 ){
                int x = num%10; 
                Dans.push_back(x); 
                num = num/10; 
            }
            int  n = Dans.size(); 
            for(int i  = n-1; i>=0; i--){
                ans.push_back(Dans[i]); 
            }
        }
    return ans ; 
    }
};
